# =============================================================================
# LimeSurvey DSFR Suite — Variables d'environnement (production)
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs.
#   cp .env.example .env
# =============================================================================

# --- Base de données ---
DB_USERNAME=limesurvey
DB_PASSWORD=CHANGEME_db_password
MYSQL_ROOT_PASSWORD=CHANGEME_root_password
MYSQL_USER=limesurvey
MYSQL_PASSWORD=CHANGEME_db_password

# --- Administration LimeSurvey ---
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGEME_admin_password
ADMIN_NAME=Administrateur
ADMIN_EMAIL=admin@example.com

# --- URL publique ---
PUBLIC_URL=https://galileo.bercy.matge.com

# --- Chiffrement (générer avec : openssl rand -hex 32) ---
# ENCRYPT_KEYPAIR=
# ENCRYPT_NONCE=
# ENCRYPT_SECRET_BOX_KEY=
